# Environment Variables

# ── HTTP Server ───────────────────────────────────────────────────────────────
HOST='localhost'                                   # Application host (default: localhost)
PORT=3000                                          # Application port (default: 3000)

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS='http://localhost:3000,http://localhost:8081'  # Comma-separated allowed origins

# ── Convex ────────────────────────────────────────────────────────────────────
CONVEX_URL='https://<your-deployment>.convex.cloud'  # Required: from `bun run setup`

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET='your-secret-key'               # Required: run `openssl rand -base64 32`
BETTER_AUTH_URL='http://localhost:3000'            # Required: base URL of your application
AUTH_DATABASE_URL='auth.db'                        # Optional: SQLite file path (default: auth.db)

# ── Payment (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY='sk_test_...'                    # Required for Phase 4: Stripe secret key
STRIPE_WEBHOOK_SECRET='whsec_...'                  # Required for Phase 4: from Stripe dashboard

# ── OCR (Google Cloud Vision) ─────────────────────────────────────────────────
GOOGLE_CLOUD_VISION_API_KEY=''                     # Required for Phase 6: prescription scanning
