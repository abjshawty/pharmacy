{
  "name": "bun-server",
  "version": "1.1.0",
  "type": "module",
  "author": "Timmy Kouadio-Bhegnin <kouadiobhegnino@gmail.com> (https://devfrombabi.ace.me/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/abjshawty/server.git"
  },
  "module": "src/index.ts",
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.5.5",
    "@elysiajs/openapi": "^1.4.14",
    "better-auth": "^1.5.5",
    "convex": "^1.31.6",
    "elysia": "^1.4.22",
    "kysely": "^0.28.15",
    "kysely-bun-worker": "^1.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "bugs": {
    "url": "https://github.com/abjshawty/server/issues",
    "email": "kouadiobhegnino@gmail.com"
  },
  "contributors": [
    "Timmy Kouadio-Bhegnin <kouadiobhegnino@gmail.com> (https://devfrombabi.ace.me/)"
  ],
  "description": "Functional template for a backend server, using Bun & Convex",
  "engineStrict": true,
  "engines": {
    "bun": ">=1.3.6"
  },
  "homepage": "https://github.com/abjshawty/server#readme",
  "keywords": [
    "bun",
    "convex",
    "server"
  ],
  "license": "WTFPL",
  "private": false,
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "dev:debug": "bun --watch --inspect src/index.ts",
    "dev:watch": "bun --hot src/index.ts",
    "setup": "convex dev",
    "typecheck": "tsc --noEmit",
    "setup:full": "bun install && bun init-db.ts && convex dev",
    "seed": "npx convex run seed:run"
  }
}
